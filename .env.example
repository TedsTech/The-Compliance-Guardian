# Bright Data MCP — SSE endpoint with sponsored groups
VITE_BRIGHTDATA_TOKEN=your_bright_data_api_token_here
VITE_BRIGHTDATA_GROUPS=advanced_scraping,social,research

# Google AI Studio API Key (free tier)
VITE_GEMINI_API_KEY=your_google_ai_studio_key_here

# Montgomery ArcGIS REST API Base
# HOW TO FIND: 
# 1. Open: https://opendata.montgomeryal.gov/apps/96a494d436c24a66821dac6792cd12f9/explore
# 2. Press F12 (DevTools) → Network tab → Reload page
# 3. Search for "services.arcgis.com" requests
# 4. Replace XXXX with the service ID from the URL
# Example: https://services.arcgis.com/abcd1234/arcgis/rest/services
VITE_MONTGOMERY_ARCGIS_BASE=https://services.arcgis.com/XXXX/arcgis/rest/services

# Bright Data MCP endpoint is auto-selected in src/lib/brightdata.js
# Dev: proxied via Vite (/brightdata-mcp) to avoid CORS
# Prod: direct to https://mcp.brightdata.com/mcp
# No config needed here — just set VITE_BRIGHTDATA_TOKEN above
